generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  username      String?      @unique
  password      String?
  role          String       @default("USER") // USER or SUPER_ADMIN
  status        String       @default("ACTIVE") // ACTIVE or SUSPENDED
  provider      String       @default("credentials") // credentials or google
  image         String?
  emailVerified Boolean      @default(false)
  otpHash       String?      // bcrypt hash of the pending verification OTP
  otpExpiresAt  DateTime?    // expiry timestamp for the OTP
  firstLoginAt  DateTime?    // Set on first successful login — used to send welcome email once
  whatsappSessionId String?  // Stores the OpenWA session ID linked to this user
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  invitations   Invitation[] @relation("InvitationOwner")
  partnerInvitations Invitation[] @relation("InvitationPartner")
  whatsappLogs  WhatsappLog[]
}

model WhatsappLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipient    String
  messageId    String?  // WAHA message ID
  content      String
  status       String   @default("PENDING") // PENDING, SENT, DELIVERED, READ, FAILED
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Invitation {
  id            String       @id @default(cuid())
  slug          String       @unique
  userId        String?
  user          User?        @relation("InvitationOwner", fields: [userId], references: [id], onDelete: Cascade)
  partnerUserId String?
  partnerUser   User?        @relation("InvitationPartner", fields: [partnerUserId], references: [id], onDelete: SetNull)
  partnerEmail  String?
  title         String       @default("The Royal Wedding Celebration")
  coupleNames   String       @default("Rahul Sharma & Priya Mehta")
  brideDetails  String       @default("Daughter of Sri K. Ramachandran & Smt. Lakshmi Devi")
  groomDetails  String       @default("Son of Sri V. Krishnan & Smt. Saraswathi")
  weddingDate   String       @default("2026-11-21T10:30:00")
  weddingDateDisplay String  @default("November 21–22, 2026")
  venueName     String       @default("The Tamarind Tree & The Leela Palace")
  venueAddress  String       @default("Bangalore, Karnataka, India")
  mapUrl        String       @default("https://maps.google.com")
  story         String       @default("Two paths crossed under the Bangalore skies, blossoming into a lifelong bond of love, laughter, and heritage.")
  theme         String       @default("alabaster") // alabaster, velvet, emerald, rose, marigold, mysore, crimson, ivory, peacock, lotus, sandalwood, banarasi
  fontStyle     String       @default("cormorant_bickham") // font pairing ID from FONT_PAIRINGS
  heroBgType    String       @default("image") // "image" or "video"
  heroBgUrl     String?      // uploaded S3/R2 URL or external URL
  musicUrl      String?
  isPublished   Boolean      @default(true)
  viewCount            Int              @default(0)
  eventsJson           String           @default("[{\"name\":\"Haldi & Mehendi\",\"time\":\"Nov 20, 4:00 PM\",\"venue\":\"Tamarind Tree Gardens\"},{\"name\":\"Muhurtham Ceremony\",\"time\":\"Nov 21, 9:30 AM\",\"venue\":\"Tamarind Tree Main Hall\"},{\"name\":\"Grand Reception Gala\",\"time\":\"Nov 22, 7:00 PM\",\"venue\":\"The Leela Palace Ballroom\"}]")
  timelineJson         String?
  faqJson              String?
  galleryJson          String           @default("[\"https://images.unsplash.com/photo-1583939003579-730e3918a45a?q=80&w=1974&auto=format&fit=crop\",\"https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=1974&auto=format&fit=crop\",\"https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=2070&auto=format&fit=crop\"]")
  enableAccommodations Boolean          @default(true)
  accommodationsTitle  String?          @default("Accommodations & Venue Directions")
  splitCoupleNames     Boolean          @default(false)
  enableEnvelope       Boolean          @default(false)
  envelopeTemplate     String           @default("classic-gold")
  rsvpDeadline         String?          // Optional RSVP cutoff/end date (ISO string e.g. 2026-10-31T23:59:59)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  rsvps                Rsvp[]
  visits               InvitationVisit[]
}

model InvitationVisit {
  id           String     @id @default(cuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  ipAddress    String
  createdAt    DateTime   @default(now())

  @@unique([invitationId, ipAddress])
}

model Rsvp {
  id            String       @id @default(cuid())
  invitationId  String?
  invitation    Invitation?  @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  guestName     String
  attending     String       @default("yes")
  guestsCount   Int          @default(1)
  dietary       String?
  events        String?      @default("Muhurtham, Reception")
  phone         String?
  createdAt     DateTime     @default(now())
}

model SupportTicket {
  id            String       @id @default(cuid())
  name          String
  emailOrPhone  String
  message       String
  status        String       @default("OPEN")
  createdAt     DateTime     @default(now())
}

model ProPayment {
  id                Int       @id @default(autoincrement())
  txId              String?   @unique @map("tx_id")
  razorpayOrderId   String?   @map("razorpay_order_id")
  razorpayPaymentId String?   @map("razorpay_payment_id")
  razorpaySignature String?   @map("razorpay_signature")
  coupleNames       String?   @map("couple_names")
  userEmail         String?   @map("user_email")
  amount            Int?      @default(0)
  currency          String?   @default("INR")
  paymentMethod     String?   @map("payment_method")
  status            String?   @default("Approved & Active")
  plan              String?   @default("PRO")
  isMock            Boolean?  @default(false) @map("is_mock")
  grantedByAdmin    Boolean?  @default(false) @map("granted_by_admin")
  createdAt         DateTime? @default(now()) @map("created_at")

  @@map("vivaha_pro_payments")
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  source    String   // register, welcome, invitation, order, payment
  status    String   // SUCCESS or FAILED
  error     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("email_logs")
}

model SystemError {
  id        String   @id @default(cuid())
  message   String
  stack     String?
  path      String?
  status    String   @default("OPEN") // OPEN, RESOLVED, DISMISSED
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_errors")
}

model SystemConfig {
  id               String   @id @default("global")
  maintenanceMode  Boolean  @default(false)
  maintenanceText  String?
  maintenanceDate  String?
  alertEnabled     Boolean  @default(false)
  alertText        String?
  updatedAt        DateTime @updatedAt

  @@map("system_config")
}

model Testimonial {
  id         String   @id @default(cuid())
  name       String   // Couple name e.g. "Ananya & Karthik Iyer"
  venue      String   // Wedding venue
  date       String   // Display date e.g. "March 2026"
  quote      String   // The testimonial text
  rating     Int      @default(5) // 1–5 stars
  theme      String   @default("") // Theme name badge e.g. "Heritage Emerald"
  themeColor String   @default("#22201E") // Badge background hex
  textColor  String   @default("#FAF8F5") // Badge text hex
  isVisible  Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("testimonials")
}
